# Mera app — copy this file to `.env` and fill in your own backend endpoints.
# All EXPO_PUBLIC_* vars are inlined into the JS bundle at build time.

# --- Required (the app HARD-CRASHES at launch if any of these three are unset;
#     see lib/config/endpoints.ts requireEnv) ---
# Better Auth service base URL. Must expose /api/auth/* (OTP + JWKS).
EXPO_PUBLIC_AUTH_ENDPOINT=https://auth.example.com
# GraphQL API base URL. Apollo appends /graphql.
EXPO_PUBLIC_GRAPHQL_SERVER_ENDPOINT=https://graphql.example.com
# Inference gateway base URL. Must expose /v1/chat/completions,
# /v1/chat/completions/batch, /v1/inference/jobs, and /api/attestation/report.
EXPO_PUBLIC_INFERENCE_ENDPOINT=https://inference.example.com

# --- Optional ---
# Sentry DSN for crash/error reporting. App runs fine if blank.
EXPO_PUBLIC_SENTRY_DSN=
# Set to "true" to dump decrypted inference prompts/results to the device
# Documents dir for debugging. Leave off in any shipped build.
EXPO_PUBLIC_DUMP_QUERY_FOR_DEBUGGING=false
# RevenueCat public SDK key. Subscriptions/paywall are disabled when unset.
# A Test Store key (test_…) works on both platforms for development. For
# production, set the platform-specific keys below instead, which take
# precedence over this one.
EXPO_PUBLIC_REVENUECAT_API_KEY=
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# --- Branding (optional; defaults to the reference mera.news values) ---
# Centralized in lib/config/branding.ts; override to rebrand the app.
EXPO_PUBLIC_PRIVACY_URL=https://example.com/privacy
EXPO_PUBLIC_TERMS_URL=https://example.com/terms
EXPO_PUBLIC_SUPPORT_EMAIL=support@example.com
EXPO_PUBLIC_WEBSITE_URL=https://example.com
EXPO_PUBLIC_GITHUB_URL=https://github.com/your-org/your-fork

# --- EAS / build (only needed for `eas build`/`update`/submit; NOT EXPO_PUBLIC_) ---
# These drive org identity via app.config.js, falling back to the committed
# app.json defaults. The simplest forker path is `eas init` + editing app.json
# directly; these env overrides are mainly for CI.
# Expo account name (app.json `owner`).
EXPO_OWNER=
# EAS project UUID (app.json `extra.eas.projectId`); also derives updates.url.
# Set automatically by `eas init`.
EAS_PROJECT_ID=
# iOS bundle identifier (reverse-DNS). Also update google-services/APNs.
APP_BUNDLE_ID=
# Android application ID / package. Must match google-services.json package_name.
APP_PACKAGE=
# App display name. Must not contain "Mera" (trademark).
APP_NAME=
# App slug. Drives auth storage-prefix keys.
APP_SLUG=
# Deep-link scheme.
APP_SCHEME=
# Path to your Firebase google-services.json (app.json android.googleServicesFile).
GOOGLE_SERVICES_FILE=
# Sentry org/project for build-time source-map upload. Blank = skip upload.
SENTRY_ORG=
SENTRY_PROJECT=
# Sentry CLI auth token for source-map upload (store as an EAS secret).
SENTRY_AUTH_TOKEN=
